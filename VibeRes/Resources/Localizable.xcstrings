      }
    },
    "Hide the per-row refresh-rate chips. Clicking a resolution applies it at the highest available refresh rate for your display. Turn off if you want to pick refresh rates manually." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blendet die einzelnen Bildwiederholraten-Chips aus. Ein Klick auf eine Auflösung wendet sie mit der höchsten verfügbaren Bildwiederholrate an. Deaktivieren, um Bildwiederholraten manuell auszuwählen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hide the per-row refresh-rate chips. Clicking a resolution applies it at the highest available refresh rate for your display. Turn off if you want to pick refresh rates manually."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skryje chipy s obnovovacou frekvenciou pri každom riadku. Kliknutie na rozlíšenie ho použije s najvyššou dostupnou frekvenciou pre tvoj displej. Vypni, ak chceš vyberať Hz manuálne."
          }
        }
      }
    },
    "Hovering a resolution row shows a real screenshot of your desktop scaled into the proposed mode. Requires Screen Recording permission, which is requested the first time you hover with this turned on." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Überfahren einer Auflösungszeile wird ein echter Screenshot deines Desktops in der vorgeschlagenen Auflösung angezeigt. Erfordert die Berechtigung „Bildschirmaufnahme“, die beim ersten Überfahren angefordert wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hovering a resolution row shows a real screenshot of your desktop scaled into the proposed mode. Requires Screen Recording permission, which is requested the first time you hover with this turned on."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pri prejdení myšou nad rozlíšením sa zobrazí skutočný snímok plochy v navrhovanom režime. Vyžaduje povolenie Nahrávanie obrazovky, ktoré sa žiada pri prvom prejdení po zapnutí."
          }
        }
      }
    },
