        "en" : { "stringUnit" : { "state" : "translated", "value" : "Update available" } },
        "sk" : { "stringUnit" : { "state" : "translated", "value" : "Dostupná aktualizácia" } }
      }
    },
    "Updates" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Aktualisierungen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Updates" } },
        "sk" : { "stringUnit" : { "state" : "translated", "value" : "Aktualizácie" } }
      }
    },
    "When you plug or unplug a monitor, VibeRes finds the saved profile that best fits the new layout and applies it silently. Mode-only changes don't trigger this." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du einen Monitor anschließt oder trennst, findet VibeRes das passendste gespeicherte Profil und wendet es lautlos an. Reine Auflösungsänderungen lösen das nicht aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When you plug or unplug a monitor, VibeRes finds the saved profile that best fits the new layout and applies it silently. Mode-only changes don't trigger this."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keď pripojíš alebo odpojíš monitor, VibeRes nájde uložený profil, ktorý najlepšie vyhovuje novému usporiadaniu, a tichu ho použije. Zmeny iba režimu (rozlíšenia) tento mechanizmus nespustia."
          }
        }
      }
    },

    "onboarding.welcome.title" : {
      "comment" : "Onboarding step 1 title",
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Willkommen bei VibeRes" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Welcome to VibeRes" } },
        "sk" : { "stringUnit" : { "state" : "translated", "value" : "Vitaj vo VibeRes" } }
      }
    },
    "onboarding.welcome.body" : {
      "comment" : "Onboarding step 1 body",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wechsle Auflösung und Bildwiederholrate jedes angeschlossenen Bildschirms direkt aus der Menüleiste. Drei kurze Schritte zeigen dir, wie."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Switch resolution and refresh rate on every connected display, straight from the menu bar. Three quick steps will show you how."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prepínaj rozlíšenie a obnovovaciu frekvenciu pre každý pripojený monitor priamo z menubar. Tri krátke kroky ti ukážu, ako na to."
          }
        }
      }
    },
    "onboarding.profiles.title" : {
      "comment" : "Onboarding step 2 title",
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Profile sparen Zeit" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Profiles save you time" } },
        "sk" : { "stringUnit" : { "state" : "translated", "value" : "Profily ti šetria čas" } }
      }
    },
    "onboarding.profiles.body" : {
      "comment" : "Onboarding step 2 body",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speichere dein gesamtes Mehrbildschirm-Setup als „Arbeit“, „Präsentation“ oder „Reise“. Ein Klick wendet alles wieder an. VibeRes kann das beste Profil auch automatisch nach dem Anschließen eines Monitors auswählen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save your whole multi-display setup as “Work”, “Presentation”, or “Travel”. One click applies everything again. VibeRes can also pick the best profile automatically after a monitor is plugged in."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ulož si celé multi-display nastavenie ako „Práca“, „Prezentácia“ alebo „Cesty“. Jeden klik všetko opäť aplikuje. VibeRes vie po pripojení monitora aj sám vybrať najvhodnejší profil."
          }
        }
      }
    },
    "onboarding.simple.title" : {
      "comment" : "Onboarding step 3 title",
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Einfacher Modus & Einstellungen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Simple Mode & Settings" } },
        "sk" : { "stringUnit" : { "state" : "translated", "value" : "Jednoduchý režim & Nastavenia" } }
      }
    },
    "onboarding.simple.body" : {
      "comment" : "Onboarding step 3 body",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Im Einfachen Modus genügt ein Klick auf eine Auflösung – die höchste verfügbare Bildwiederholrate wird automatisch gewählt. Profis können das in den Einstellungen (⌘,) ausschalten und dort auch die Live-Vorschau und automatische Updates regeln."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In Simple Mode one click on a resolution applies it at the highest refresh rate. Power users can turn it off in Settings (⌘,), where Live Preview and update preferences live too."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V Jednoduchom režime stačí jeden klik na rozlíšenie — použije sa s najvyššou Hz. Pokročilí ho môžu vypnúť v Nastaveniach (⌘,), kde sú aj možnosti živého náhľadu a aktualizácií."
          }
        }
      }
    },
    "onboarding.step" : {
      "comment" : "Step indicator, e.g. 'Step 2 of 3'",
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Schritt %1$d von %2$d" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Step %1$d of %2$d" } },
        "sk" : { "stringUnit" : { "state" : "translated", "value" : "Krok %1$d z %2$d" } }
      }
    }
  }
}
